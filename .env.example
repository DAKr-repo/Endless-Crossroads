# CoD:EX Environment Configuration
# Copy this file to .env and fill in your values.

# Discord bot token (from Discord Developer Portal)
DISCORD_TOKEN=''

# Telegram bot token (from @BotFather)
TELEGRAM_TOKEN=''

# Discord admin user ID (right-click your profile > Copy User ID)
ADMIN_ID=''

# Google Gemini API key (from Google AI Studio) — optional
GEMINI_API_KEY=

# Path to knowledge pool directory (wiki ZIM files) — optional
# KNOWLEDGE_POOL=/path/to/knowledge_pool
