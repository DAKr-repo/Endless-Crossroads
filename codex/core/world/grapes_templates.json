  "culture": {
    "values": [
      {"tenet": "Hospitality above all", "expression": "No stranger sleeps outside the walls", "consequence": "Innkeepers hold political power equal to mayors"},
      {"tenet": "Truth in all dealings", "expression": "Contracts spoken aloud before witnesses are sacred", "consequence": "Liars are branded and exiled permanently"},
      {"tenet": "Honour the craft", "expression": "Every citizen masters one trade before adulthood", "consequence": "The unguilded are considered incomplete persons"},
      {"tenet": "Strength through unity", "expression": "No family eats until all families eat", "consequence": "Communal granaries are defended more fiercely than temples"},
      {"tenet": "Respect the cycle", "expression": "Nothing is wasted; all returns to the earth", "consequence": "Funeral rites double as planting ceremonies"},
      {"tenet": "Courage before comfort", "expression": "Children face a trial of endurance at age twelve", "consequence": "Cowardice in battle strips citizenship rights"},
      {"tenet": "Knowledge is power", "expression": "Libraries are guarded as fiercely as treasuries", "consequence": "Illiteracy is punished; scribes outrank soldiers"},
      {"tenet": "Mercy to the fallen", "expression": "Defeated enemies are offered shelter and rehabilitation", "consequence": "Prisons do not exist; all captives must be sponsored by a family"},
      {"tenet": "Balance in all things", "expression": "Every act of creation must be matched by an act of sacrifice", "consequence": "Artists destroy one old work for every new piece completed"},
      {"tenet": "Freedom of movement", "expression": "No gate may bar a peaceful traveller", "consequence": "Borders are ceremonial; passports are considered offensive"},
      {"tenet": "Ancestor reverence", "expression": "The dead advise the living through dream-oracles", "consequence": "Major decisions require consulting an ancestor shrine"},
      {"tenet": "The commons belong to all", "expression": "Rivers, forests, and mineral veins cannot be privately owned", "consequence": "Resource hoarding is the gravest crime"},
      {"tenet": "Earn your name", "expression": "Birth names are replaced by deed-names at maturity", "consequence": "The unnamed hold no legal standing in courts"},
      {"tenet": "Art reveals truth", "expression": "Public art critiquing leaders is protected speech", "consequence": "Censorship attempts provoke immediate civic unrest"},
      {"tenet": "Protect the young", "expression": "Harm to a child calls the entire community to arms", "consequence": "Orphans are raised collectively; adoption is automatic"}
    ]
  },
